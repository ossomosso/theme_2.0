{% doc %}
  @prompt
    Genera una sección que sea un espacio que solo tenga margen 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spacer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-spacer-{{ ai_gen_id }} {
      margin-top: {{ block.settings.margin_top_mobile }}px;
      margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-spacer-{{ ai_gen_id }}" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "Espaciador",
  "settings": [
    {
      "type": "header",
      "content": "Escritorio"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margen superior",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margen inferior",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Móvil"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Margen superior",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Margen inferior",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Espaciador"
    }
  ]
}
{% endschema %}
