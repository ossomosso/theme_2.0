{% doc %}
  @prompt
    Crea una sección que deje espacio solo en desktop y en no en mobile
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spacer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .ai-spacer-{{ ai_gen_id }} {
      height: {{ block.settings.desktop_spacing }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-spacer-{{ ai_gen_id }} {
      height: 0;
    }
  }
{% endstyle %}

<div class="ai-spacer-{{ ai_gen_id }}" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "Espaciador",
  "settings": [
    {
      "type": "range",
      "id": "desktop_spacing",
      "label": "Espaciado en desktop",
      "min": 10,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Espaciador"
    }
  ]
}
{% endschema %}
