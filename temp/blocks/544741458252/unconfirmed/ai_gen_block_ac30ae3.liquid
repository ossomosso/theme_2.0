{% doc %}
  @prompt
    Crea un bloque que deje un margin-top solo en desktop
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-desktop-spacer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .ai-desktop-spacer-{{ ai_gen_id }} {
      margin-top: {{ block.settings.desktop_margin_top }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-desktop-spacer-{{ ai_gen_id }} {
      margin-top: 0;
    }
  }
{% endstyle %}

<div class="ai-desktop-spacer-{{ ai_gen_id }}" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "Margen superior desktop",
  "settings": [
    {
      "type": "range",
      "id": "desktop_margin_top",
      "label": "Margen superior",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Margen superior desktop"
    }
  ]
}
{% endschema %}
