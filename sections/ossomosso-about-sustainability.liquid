{% comment %}
  Ossomosso About Sustainability Section
  Two-column: visual left, content right with stats
{% endcomment %}

<style>
  .osso-about-sustainability {
    padding: 120px 48px;
    max-width: 1100px;
    margin: 0 auto;
    background: var(--color-background);
  }

  .osso-about-sustainability__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .osso-about-sustainability__visual {
    background: var(--color-background);
    opacity: 0.9;
    min-height: 480px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .osso-about-sustainability__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .osso-about-sustainability__label {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary);
    font-weight: 500;
    margin-bottom: 16px;
    font-family: var(--font-body--family);
  }

  .osso-about-sustainability__title {
    font-family: var(--font-heading--family);
    font-size: clamp(32px, 3.5vw, 52px);
    font-weight: 300;
    line-height: 1.1;
    color: var(--color-foreground);
    margin-bottom: 24px;
  }

  .osso-about-sustainability__title em {
    font-style: italic;
    color: var(--color-primary);
  }

  .osso-about-sustainability__body {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-foreground);
    opacity: 0.6;
    font-family: var(--font-body--family);
    font-weight: 300;
  }

  .osso-about-sustainability__body + .osso-about-sustainability__body {
    margin-top: 16px;
  }

  .osso-about-sustainability__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-top: 40px;
  }

  .osso-about-sustainability__stat-num {
    font-family: var(--font-heading--family);
    font-size: 44px;
    font-weight: 300;
    color: var(--color-foreground);
    line-height: 1;
  }

  .osso-about-sustainability__stat-label {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-foreground);
    opacity: 0.5;
    margin-top: 8px;
    font-family: var(--font-body--family);
  }

  @media (max-width: 900px) {
    .osso-about-sustainability {
      padding: 80px 24px;
    }

    .osso-about-sustainability__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>

<section class="osso-about-sustainability" data-section-id="{{ section.id }}">
  <div class="osso-about-sustainability__inner">
    <div class="osso-about-sustainability__visual">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
      {% else %}
        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
          <span style="font-size: 14px; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.4;">Visual</span>
        </div>
      {% endif %}
    </div>

    <div>
      {% if section.settings.label != blank %}
        <p class="osso-about-sustainability__label">{{ section.settings.label }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="osso-about-sustainability__title">
          {{ section.settings.title }}
          {% if section.settings.title_emphasis != blank %}
            <em>{{ section.settings.title_emphasis }}</em>
          {% endif %}
        </h2>
      {% endif %}

      {% if section.settings.body_1 != blank %}
        <p class="osso-about-sustainability__body">{{ section.settings.body_1 }}</p>
      {% endif %}

      {% if section.settings.body_2 != blank %}
        <p class="osso-about-sustainability__body">{{ section.settings.body_2 }}</p>
      {% endif %}

      <div class="osso-about-sustainability__stats">
        {% for block in section.blocks %}
          <div class="osso-about-sustainability__stat" {{ block.shopify_attributes }}>
            {% if block.settings.number != blank %}
              <p class="osso-about-sustainability__stat-num">{{ block.settings.number }}</p>
            {% endif %}
            {% if block.settings.label != blank %}
              <p class="osso-about-sustainability__stat-label">{{ block.settings.label }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ossomosso - About Sustainability",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Sostenibilidad"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Tecnología con"
    },
    {
      "type": "text",
      "id": "title_emphasis",
      "label": "Title emphasis (italic)",
      "default": "conciencia"
    },
    {
      "type": "textarea",
      "id": "body_1",
      "label": "Body paragraph 1",
      "default": "La impresión 3D nos permite crear solo lo necesario. Sin moldes costosos, sin mínimos de producción, sin inventario dormido. Fabricamos cuando necesitamos, con los materiales adecuados, en el lugar donde vivimos."
    },
    {
      "type": "textarea",
      "id": "body_2",
      "label": "Body paragraph 2",
      "default": "Nuestros materiales son biodegradables y de origen vegetal. Nuestro packaging es minimalista y reciclado. Nuestro objetivo: objetos hermosos que no dejen huella."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Visual image"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "100%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "PLA biodegradable"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ossomosso - About Sustainability"
    }
  ]
}
{% endschema %}
