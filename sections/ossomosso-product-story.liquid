{% liquid
  assign featured_image = product.featured_image
  assign secondary_image = product.media[1].preview_image | default: featured_image
  assign tertiary_image = product.media[2].preview_image | default: secondary_image
  assign selected_variant = product.selected_or_first_available_variant
%}

<section class="osso-product-story color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}">
  {% for block in section.blocks %}
    {% case block.type %}

      {% when 'marquee' %}
        <div class="osso-product-story__marquee" aria-hidden="true" {{ block.shopify_attributes }}>
          <div class="osso-product-story__marquee-track" style="animation-duration: {{ block.settings.speed | default: 26 }}s;">
            {% for i in (1..5) %}
              {% capture item_key %}item_{{ i }}{% endcapture %}
              {% assign item_text = block.settings[item_key] %}
              {% if item_text != blank %}
                <span>{{ item_text }}</span>
                {% unless forloop.last %}
                  <span class="osso-product-story__marquee-dot">·</span>
                {% endunless %}
              {% endif %}
            {% endfor %}
            {% comment %} Duplicate for seamless loop {% endcomment %}
            {% for i in (1..5) %}
              {% capture item_key %}item_{{ i }}{% endcapture %}
              {% assign item_text = block.settings[item_key] %}
              {% if item_text != blank %}
                <span>{{ item_text }}</span>
                {% unless forloop.last %}
                  <span class="osso-product-story__marquee-dot">·</span>
                {% endunless %}
              {% endif %}
            {% endfor %}
          </div>
        </div>

      {% when 'intro' %}
        <div class="osso-product-story__intro" {{ block.shopify_attributes }}>
          <div class="osso-product-story__intro-copy">
            {% if block.settings.eyebrow != blank %}
              <p class="osso-product-story__eyebrow">{{ block.settings.eyebrow }}</p>
            {% endif %}
            {% if block.settings.title != blank %}
              <h2 class="osso-product-story__title">{{ block.settings.title }}</h2>
            {% endif %}
            {% if block.settings.body != blank %}
              <div class="osso-product-story__text rte">{{ block.settings.body }}</div>
            {% endif %}
          </div>
          {% if block.settings.show_specs %}
            <div class="osso-product-story__specs">
              {% for i in (1..4) %}
                {% capture label_key %}spec_{{ i }}_label{% endcapture %}
                {% capture value_key %}spec_{{ i }}_value{% endcapture %}
                {% assign spec_label = block.settings[label_key] %}
                {% assign spec_value = block.settings[value_key] %}
                {% if spec_label != blank or spec_value != blank %}
                  <div class="osso-product-story__spec">
                    {% if spec_label != blank %}
                      <span class="osso-product-story__spec-label">{{ spec_label }}</span>
                    {% endif %}
                    {% if spec_value != blank %}
                      <span class="osso-product-story__spec-value">{{ spec_value }}</span>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        </div>

      {% when 'features' %}
        <div class="osso-product-story__features" {{ block.shopify_attributes }}>
          {% for i in (1..4) %}
            {% capture title_key %}feature_{{ i }}_title{% endcapture %}
            {% capture text_key %}feature_{{ i }}_text{% endcapture %}
            {% assign feature_title = block.settings[title_key] %}
            {% assign feature_text = block.settings[text_key] %}
            {% if feature_title != blank or feature_text != blank %}
              <article class="osso-product-story__feature">
                {% if feature_title != blank %}
                  <h3 class="osso-product-story__feature-title">{{ feature_title }}</h3>
                {% endif %}
                {% if feature_text != blank %}
                  <p class="osso-product-story__feature-copy">{{ feature_text }}</p>
                {% endif %}
              </article>
            {% endif %}
          {% endfor %}
        </div>

      {% when 'media_grid' %}
        <div class="osso-product-story__grid" {{ block.shopify_attributes }}>
          {% for i in (1..4) %}
            {% capture type_key %}card_{{ i }}_type{% endcapture %}
            {% capture image_key %}card_{{ i }}_image{% endcapture %}
            {% capture kicker_key %}card_{{ i }}_kicker{% endcapture %}
            {% capture title_key %}card_{{ i }}_title{% endcapture %}
            {% capture text_key %}card_{{ i }}_text{% endcapture %}
            {% capture dark_key %}card_{{ i }}_dark{% endcapture %}
            {% assign card_type = block.settings[type_key] %}
            {% assign card_image = block.settings[image_key] %}
            {% assign card_kicker = block.settings[kicker_key] %}
            {% assign card_title = block.settings[title_key] %}
            {% assign card_text = block.settings[text_key] %}
            {% assign card_dark = block.settings[dark_key] %}

            {% if card_type == 'image' %}
              <article class="osso-product-story__card osso-product-story__card--image">
                {% if card_image != blank %}
                  {{ card_image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '480, 720, 960, 1400', class: 'osso-product-story__image', alt: product.title }}
                {% elsif featured_image != blank %}
                  {{ featured_image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '480, 720, 960, 1400', class: 'osso-product-story__image', alt: product.title }}
                {% endif %}
              </article>
            {% else %}
              <article class="osso-product-story__card osso-product-story__card--text{% if card_dark %} osso-product-story__card--dark{% endif %}">
                {% if card_kicker != blank %}
                  <p class="osso-product-story__card-kicker">{{ card_kicker }}</p>
                {% endif %}
                {% if card_title != blank %}
                  <h3 class="osso-product-story__card-title">{{ card_title }}</h3>
                {% endif %}
                {% if card_text != blank %}
                  <p class="osso-product-story__card-copy">{{ card_text }}</p>
                {% endif %}
              </article>
            {% endif %}
          {% endfor %}
        </div>

      {% when 'highlight' %}
        <div class="osso-product-story__highlight" {{ block.shopify_attributes }}>
          <div class="osso-product-story__highlight-media">
            {% if block.settings.media != blank %}
              {{ block.settings.media | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '480, 720, 960, 1400', class: 'osso-product-story__image', alt: product.title }}
            {% elsif tertiary_image != blank %}
              {{ tertiary_image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '480, 720, 960, 1400', class: 'osso-product-story__image', alt: product.title }}
            {% endif %}
          </div>
          <div class="osso-product-story__highlight-copy">
            {% if block.settings.eyebrow != blank %}
              <p class="osso-product-story__eyebrow">{{ block.settings.eyebrow }}</p>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="osso-product-story__highlight-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="osso-product-story__card-copy">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        </div>

      {% when 'details' %}
        <div class="osso-product-story__details" {{ block.shopify_attributes }}>
          <div class="osso-product-story__details-visual">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '480, 720, 960, 1400', class: 'osso-product-story__details-image', alt: product.title }}
            {% elsif featured_image != blank %}
              {{ featured_image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '480, 720, 960, 1400', class: 'osso-product-story__details-image', alt: product.title }}
            {% endif %}
          </div>
          <div class="osso-product-story__details-copy">
            {% if block.settings.eyebrow != blank %}
              <p class="osso-product-story__eyebrow">{{ block.settings.eyebrow }}</p>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="osso-product-story__section-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="osso-product-story__text rte">{{ block.settings.text }}</div>
            {% endif %}
            {% if block.settings.show_accordion %}
              <div class="osso-product-story__accordion">
                {% for i in (1..3) %}
                  {% capture heading_key %}accordion_{{ i }}_heading{% endcapture %}
                  {% capture content_key %}accordion_{{ i }}_content{% endcapture %}
                  {% assign acc_heading = block.settings[heading_key] %}
                  {% assign acc_content = block.settings[content_key] %}
                  {% if acc_heading != blank %}
                    <details class="osso-product-story__accordion-item">
                      <summary>{{ acc_heading }}</summary>
                      {% if acc_content != blank %}
                        <div class="osso-product-story__accordion-body rte">{{ acc_content }}</div>
                      {% endif %}
                    </details>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>

      {% when 'tech_specs' %}
        <div class="osso-product-story__tech" {{ block.shopify_attributes }}>
          <div class="osso-product-story__tech-inner">
            {% if block.settings.label != blank %}
              <p class="osso-product-story__eyebrow osso-product-story__eyebrow--light">{{ block.settings.label }}</p>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="osso-product-story__section-title osso-product-story__section-title--light">{{ block.settings.title }}</h3>
            {% endif %}
            <div class="osso-product-story__tech-grid">
              {% for i in (1..8) %}
                {% capture value_key %}spec_{{ i }}_value{% endcapture %}
                {% capture label_key %}spec_{{ i }}_label{% endcapture %}
                {% assign spec_value = block.settings[value_key] %}
                {% assign spec_label = block.settings[label_key] %}
                {% if spec_value != blank or spec_label != blank %}
                  <div class="osso-product-story__tech-item">
                    {% if spec_value != blank %}
                      <div class="osso-product-story__tech-value">{{ spec_value }}</div>
                    {% endif %}
                    {% if spec_label != blank %}
                      <div class="osso-product-story__tech-label">{{ spec_label }}</div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>

      {% when 'reviews' %}
        <div class="osso-product-story__reviews" {{ block.shopify_attributes }}>
          <div class="osso-product-story__reviews-header">
            <div>
              {% if block.settings.label != blank %}
                <p class="osso-product-story__eyebrow">{{ block.settings.label }}</p>
              {% endif %}
              {% if block.settings.title != blank %}
                <h3 class="osso-product-story__section-title">{{ block.settings.title }}</h3>
              {% endif %}
            </div>
            {% if block.settings.rating_text != blank %}
              <div class="osso-product-story__reviews-summary">{{ block.settings.rating_text }}</div>
            {% endif %}
          </div>
          <div class="osso-product-story__reviews-grid">
            {% for i in (1..3) %}
              {% capture stars_key %}review_{{ i }}_stars{% endcapture %}
              {% capture text_key %}review_{{ i }}_text{% endcapture %}
              {% capture author_key %}review_{{ i }}_author{% endcapture %}
              {% assign review_stars = block.settings[stars_key] %}
              {% assign review_text = block.settings[text_key] %}
              {% assign review_author = block.settings[author_key] %}
              {% if review_text != blank %}
                <article class="osso-product-story__review">
                  {% if review_stars > 0 %}
                    <p class="osso-product-story__review-stars">
                      {% for s in (1..5) %}
                        {% if s <= review_stars %}★{% else %}☆{% endif %}
                      {% endfor %}
                    </p>
                  {% endif %}
                  <p class="osso-product-story__review-text">{{ review_text }}</p>
                  {% if review_author != blank %}
                    <p class="osso-product-story__review-author">{{ review_author }}</p>
                  {% endif %}
                </article>
              {% endif %}
            {% endfor %}
          </div>
        </div>

    {% endcase %}
  {% endfor %}
</section>

{% stylesheet %}
  .osso-product-story {
    padding: 18px 0 90px;
  }

  .osso-product-story__intro,
  .osso-product-story__highlight,
  .osso-product-story__grid,
  .osso-product-story__features,
  .osso-product-story__details,
  .osso-product-story__reviews {
    width: min(1200px, calc(100vw - 48px));
    margin: 0 auto;
  }

  .osso-product-story__marquee {
    overflow: hidden;
    white-space: nowrap;
    border-block: 1px solid color-mix(in srgb, var(--color-foreground) 10%, transparent);
    margin-bottom: 42px;
    background: color-mix(in srgb, var(--color-foreground) 3%, var(--color-background));
  }

  .osso-product-story__marquee-track {
    display: inline-block;
    padding: 14px 0;
    animation: osso-product-story-marquee 26s linear infinite;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .osso-product-story__marquee-dot {
    margin: 0 18px;
    opacity: 0.45;
  }

  .osso-product-story__intro {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(320px, 0.9fr);
    gap: 40px;
    padding: 18px 0 48px;
    align-items: end;
  }

  .osso-product-story__eyebrow,
  .osso-product-story__card-kicker,
  .osso-product-story__spec-label,
  .osso-product-story__tech-label {
    margin: 0 0 12px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.62;
  }

  .osso-product-story__eyebrow--light {
    opacity: 0.5;
  }

  .osso-product-story__title,
  .osso-product-story__highlight-title,
  .osso-product-story__card-title,
  .osso-product-story__section-title {
    margin: 0;
    font-family: var(--font-heading--family);
    font-weight: 300;
    line-height: 1;
  }

  .osso-product-story__title {
    font-size: clamp(2.4rem, 6vw, 5rem);
    max-width: 11ch;
    margin-bottom: 20px;
  }

  .osso-product-story__section-title {
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    max-width: 10ch;
    margin-bottom: 18px;
  }

  .osso-product-story__section-title--light {
    color: var(--color-background);
  }

  .osso-product-story__text,
  .osso-product-story__card-copy,
  .osso-product-story__feature-copy,
  .osso-product-story__accordion-body,
  .osso-product-story__review-text {
    font-size: 15px;
    line-height: 1.8;
    opacity: 0.76;
  }

  .osso-product-story__text p,
  .osso-product-story__card-copy,
  .osso-product-story__highlight-copy p,
  .osso-product-story__details-copy p {
    margin: 0;
  }

  .osso-product-story__text p + p,
  .osso-product-story__details-copy p + p {
    margin-top: 14px;
  }

  .osso-product-story__specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .osso-product-story__spec {
    padding: 18px;
    border-radius: 18px;
    background: color-mix(in srgb, var(--color-foreground) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-foreground) 10%, transparent);
    display: grid;
    gap: 4px;
  }

  .osso-product-story__spec-label {
    margin-bottom: 0;
  }

  .osso-product-story__spec-value {
    font-size: 1rem;
    line-height: 1.4;
  }

  .osso-product-story__features {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 18px;
  }

  .osso-product-story__feature {
    background: color-mix(in srgb, var(--color-foreground) 4%, var(--color-background));
    border: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
    border-radius: 24px;
    padding: 26px 22px;
  }

  .osso-product-story__feature-title {
    font-family: var(--font-heading--family);
    font-size: 1.45rem;
    font-weight: 400;
    line-height: 1.1;
    margin: 0 0 10px;
  }

  .osso-product-story__feature-copy {
    margin: 0;
  }

  .osso-product-story__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin-bottom: 18px;
  }

  .osso-product-story__card {
    border-radius: 28px;
    overflow: hidden;
    min-height: 320px;
    background: color-mix(in srgb, var(--color-foreground) 4%, var(--color-background));
  }

  .osso-product-story__card--text {
    padding: clamp(28px, 4vw, 44px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .osso-product-story__card--dark {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .osso-product-story__card-title {
    font-size: clamp(2rem, 4vw, 3.4rem);
    max-width: 8ch;
    margin-bottom: 14px;
  }

  .osso-product-story__image,
  .osso-product-story__details-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    aspect-ratio: 1 / 1;
  }

  .osso-product-story__highlight {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: 18px;
    align-items: stretch;
    margin-bottom: 18px;
  }

  .osso-product-story__highlight-media,
  .osso-product-story__highlight-copy,
  .osso-product-story__details-visual {
    border-radius: 28px;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-foreground) 4%, var(--color-background));
  }

  .osso-product-story__highlight-copy {
    padding: clamp(28px, 4vw, 48px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .osso-product-story__highlight-title {
    font-size: clamp(2rem, 4vw, 3.4rem);
    max-width: 10ch;
    margin-bottom: 16px;
  }

  .osso-product-story__details {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 24px;
    align-items: stretch;
    margin-bottom: 18px;
  }

  .osso-product-story__details-copy {
    padding: clamp(24px, 4vw, 46px);
    border-radius: 28px;
    background: color-mix(in srgb, var(--color-foreground) 4%, var(--color-background));
  }

  .osso-product-story__accordion {
    margin-top: 26px;
    border-top: 1px solid color-mix(in srgb, var(--color-foreground) 12%, transparent);
  }

  .osso-product-story__accordion-item {
    border-bottom: 1px solid color-mix(in srgb, var(--color-foreground) 12%, transparent);
  }

  .osso-product-story__accordion-item summary {
    list-style: none;
    cursor: pointer;
    padding: 18px 0;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .osso-product-story__accordion-item summary::-webkit-details-marker {
    display: none;
  }

  .osso-product-story__accordion-item summary::after {
    content: '+';
    font-size: 20px;
    font-weight: 300;
    opacity: 0.6;
  }

  .osso-product-story__accordion-item[open] summary::after {
    content: '−';
  }

  .osso-product-story__accordion-body {
    padding: 0 0 18px;
  }

  .osso-product-story__tech {
    background: var(--color-foreground);
    color: var(--color-background);
    margin: 28px 0;
    padding: 72px 0;
  }

  .osso-product-story__tech-inner {
    width: min(1200px, calc(100vw - 48px));
    margin: 0 auto;
  }

  .osso-product-story__tech-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 34px;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .osso-product-story__tech-item {
    padding: 28px 24px;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .osso-product-story__tech-value {
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 4vw, 3.3rem);
    font-weight: 300;
    line-height: 1;
    margin-bottom: 8px;
  }

  .osso-product-story__tech-label {
    margin: 0;
    color: rgba(255, 255, 255, 0.56);
  }

  .osso-product-story__reviews {
    padding-top: 22px;
  }

  .osso-product-story__reviews-header {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: end;
    margin-bottom: 28px;
  }

  .osso-product-story__reviews-summary {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.58;
    white-space: nowrap;
  }

  .osso-product-story__reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .osso-product-story__review {
    padding: 28px;
    border-radius: 24px;
    background: color-mix(in srgb, var(--color-foreground) 4%, var(--color-background));
    border: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
  }

  .osso-product-story__review-stars {
    margin: 0 0 14px;
    letter-spacing: 0.2em;
    color: #bf744c;
  }

  .osso-product-story__review-text {
    font-family: var(--font-heading--family);
    font-size: 1.45rem;
    line-height: 1.55;
    margin: 0 0 18px;
    opacity: 1;
  }

  .osso-product-story__review-author {
    margin: 0;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.56;
  }

  @keyframes osso-product-story-marquee {
    0% {
      transform: translateX(0);
    }

    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 989px) {
    .osso-product-story {
      padding-bottom: 64px;
    }

    .osso-product-story__intro,
    .osso-product-story__grid,
    .osso-product-story__highlight,
    .osso-product-story__details,
    .osso-product-story__features,
    .osso-product-story__reviews-grid,
    .osso-product-story__tech-grid {
      grid-template-columns: 1fr;
    }

    .osso-product-story__intro,
    .osso-product-story__highlight,
    .osso-product-story__grid,
    .osso-product-story__features,
    .osso-product-story__details,
    .osso-product-story__reviews,
    .osso-product-story__tech-inner {
      width: min(100vw - 32px, 720px);
    }

    .osso-product-story__card,
    .osso-product-story__highlight-media,
    .osso-product-story__highlight-copy,
    .osso-product-story__details-copy,
    .osso-product-story__details-visual {
      min-height: 0;
    }

    .osso-product-story__tech {
      padding: 54px 0;
    }

    .osso-product-story__tech-grid {
      border-left: 0;
    }

    .osso-product-story__tech-item {
      border-left: 1px solid rgba(255, 255, 255, 0.1);
    }

    .osso-product-story__reviews-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 749px) {
    .osso-product-story {
      padding-top: 12px;
    }

    .osso-product-story__marquee {
      margin-bottom: 24px;
    }

    .osso-product-story__intro {
      padding-bottom: 32px;
    }

    .osso-product-story__specs {
      grid-template-columns: 1fr;
    }

    .osso-product-story__title,
    .osso-product-story__card-title,
    .osso-product-story__highlight-title,
    .osso-product-story__section-title {
      max-width: none;
    }
  }
